{
  "manifest_version": 3,
  "name": "Conspiracy Alert",
  "version": "1.0.0",
  "options_page": "options.html",
  "action": {
    "default_popup": "index.html",
    "default_icon": "src/logo.png"
  },
  "icons": {
    "16": "src/logo.png",
    "48": "src/logo.png",
    "128": "src/logo.png"
  },
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/contentScript.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
